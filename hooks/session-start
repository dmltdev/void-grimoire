#!/usr/bin/env bash
# SessionStart hook for void-grimoire plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read entry-point skill content
entry_point_content=$(cat "${PLUGIN_ROOT}/skills/use-void-grimoire/SKILL.md" 2>&1 || echo "Error reading use-void-grimoire skill")

# Read registry
REGISTRY=$(cat "$PLUGIN_ROOT/skills/registry.json")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

entry_point_escaped=$(escape_for_json "$entry_point_content")
registry_escaped=$(escape_for_json "$REGISTRY")
session_context="<EXTREMELY_IMPORTANT>\nYou have void-grimoire.\n\n**Below is the full content of your 'use-void-grimoire' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${entry_point_escaped}\n\n**Skill Registry:**\n\n${registry_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context.
# Claude Code hooks expect hookSpecificOutput.additionalContext.
# Claude Code reads BOTH fields without deduplication, so we must only
# emit the field consumed by the current platform to avoid double injection.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT — emit only hookSpecificOutput
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  # Other platforms (Cursor, etc.) — emit only additional_context
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
